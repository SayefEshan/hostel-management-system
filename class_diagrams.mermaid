classDiagram
    %% User Management Classes
    class User {
        +int id
        +string username
        +string email
        +string password
        +string first_name
        +string last_name
        +boolean is_active
        +datetime date_joined
        +datetime last_login
        +login()
        +logout()
        +change_password()
        +update_profile()
    }

    class CustomUser {
        +string user_type
        +string phone
        +string emergency_contact
        +string profile_picture
        +get_user_type()
        +get_full_name()
        +is_student()
        +is_staff()
    }

    class StudentProfile {
        +string student_id
        +string department
        +int academic_year
        +int semester
        +string faculty
        +datetime enrollment_date
        +boolean is_active
        +get_academic_info()
        +get_room_status()
        +get_complaints()
    }

    class StaffProfile {
        +string employee_id
        +string designation
        +string department
        +datetime joining_date
        +get_assigned_complaints()
        +get_managed_rooms()
    }

    %% Relationships
    User <|-- CustomUser
    CustomUser ||--|| StudentProfile
    CustomUser ||--|| StaffProfile